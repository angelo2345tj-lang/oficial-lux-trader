{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "react-jsx",

    "strict": true,

    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "noEmit": true,

    "types": [
      "vite/client",
      "node"
    ]
  },

  "include": [
    "src",
    "vite.config.ts",
    "App.tsx",
    "index.tsx",
    "components",
    "hooks",
    "services",
    "context",
    "engines",
    "utils",
    "constants",
    "types.ts",
    "constants.ts"
  ],

  "exclude": [
    "backend",
    "dist",
    "node_modules"
  ]
}
