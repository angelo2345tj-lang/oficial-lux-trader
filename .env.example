# === Backend (Render / Vercel API — NUNCA no frontend) ===
PORT=3001
GEMINI_API_KEY=your_gemini_api_key
TWELVE_DATA_KEY=your_twelve_data_key
FINNHUB_KEY=your_finnhub_key
# Domínios do frontend (Vercel, Netlify, local)
CORS_ORIGIN=http://localhost:3000,https://oficial-lux-trader.vercel.app
EXECUTION_ENABLED=false
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
MT5_BRIDGE_URL=http://127.0.0.1:8080
POCKET_BRIDGE_URL=
JWT_SECRET=change_me_in_production
DATABASE_URL=postgresql://lux:lux_secret@localhost:5432/lux_trader
REDIS_URL=redis://localhost:6379

# === Frontend Vite (variáveis de BUILD na Vercel) ===

# Opção A — Mesma origem (dev com proxy Vite ou Vercel/Netlify com rewrites em vercel.toml/netlify.toml):
# VITE_API_URL=/api/v1

# Opção B — API em domínio separado (recomendado se NÃO usar rewrites):
# URL completa da API NestJS (com ou sem /api/v1 no final):
VITE_API_URL=https://lux-trader-api.onrender.com/api/v1

# Opção C — Apenas origem da API (health em /health, analyze em /api/v1/signals/analyze):
# VITE_API_ORIGIN=https://lux-trader-api.onrender.com

# Se o backend estiver em outro projeto Vercel:
# VITE_API_URL=https://seu-backend.vercel.app/api/v1

# === Offline-first (padrão em dev — motor local + Binance público) ===
# Não defina nada → RealSignalEngine local + Binance WS/REST (sem backend :3001)
# VITE_ENABLE_REMOTE_API=false

# === Dev com backend NestJS local (:3001) — sync PC/celular via API ===
# VITE_ENABLE_REMOTE_API=true
# VITE_API_PROXY=http://127.0.0.1:3001
# VITE_API_URL=/api/v1

# === Dev crypto-only (sem backend, sinais locais) — recomendado PC novo ===
# Deixe VITE_ENABLE_REMOTE_API unset ou false
# Binance público não exige chave para BTCUSD/ETHUSD

# === Produção Vercel (cross-device determinístico) ===
# VITE_API_URL=/api/v1
# (rewrites em vercel.json → lux-trader-api.onrender.com)

# Não coloque chaves Gemini/Twelve/Finnhub no frontend.
