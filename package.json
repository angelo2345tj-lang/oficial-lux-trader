{
  "name": "lux-trader-fx",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"vite\" \"npm run start:dev --prefix backend\"",
    "dev:web": "vite",
    "dev:api": "npm run start:dev --prefix backend",
    "dev:all": "npm run dev",
    "build": "vite build",
    "build:web": "vite build",
    "build:mobile": "cross-env CAPACITOR=true vite build",
    "build:api": "npm run build --prefix backend",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "cap:sync": "npm run build:mobile && npx cap sync",
    "cap:sync:android": "npm run build:mobile && npx cap sync android",
    "cap:open:android": "npx cap open android",
    "cap:run:android": "npm run cap:sync:android && npx cap run android",
    "android:debug": "npm run cap:sync:android && cd android && gradlew assembleDebug",
    "android:release": "npm run cap:sync:android && cd android && gradlew bundleRelease"
  },
  "dependencies": {
    "@capacitor-community/http": "^1.4.0",
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/device": "^7.0.1",
    "@capacitor/filesystem": "^7.1.1",
    "@capacitor/haptics": "^7.0.1",
    "@capacitor/keyboard": "^7.0.1",
    "@capacitor/local-notifications": "^7.0.1",
    "@capacitor/network": "^7.0.1",
    "@capacitor/preferences": "^7.0.1",
    "@capacitor/push-notifications": "^7.0.1",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "@google/genai": "^1.38.0",
    "framer-motion": "^12.40.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@types/node": "^22.14.0",
    "cross-env": "^7.0.3",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
